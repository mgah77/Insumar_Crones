<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Heredamos la vista FORMULARIO de la PLANTILLA del producto -->
        <record id="product_template_auto_fix_form" model="ir.ui.view">
            <field name="name">product.template.auto.fix.form</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_form_view"/>
            <field name="arch" type="xml">
                
                <!-- Buscamos la pestaña de Inventario -->
                <xpath expr="//page[@name='inventory']" position="inside">
                    
                    <!-- Agrupamos nuestros campos dentro de la pestaña inventario -->
                    <group string="Configuración de Ajuste Automático">
                        <group>
                            <field name="enable_auto_fix"/>
                            <field name="fixed_stock_quantity" attrs="{'invisible': [('enable_auto_fix', '=', False)]}"/>
                        </group>
                    </group>
                    
                </xpath>
            </field>
        </record>
    </data>
</odoo>