<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_warehouse_auto_fix_form" model="ir.ui.view">
            <field name="name">stock.warehouse.auto.fix.form</field>
            <field name="model">stock.warehouse</field>
            <field name="inherit_id" ref="stock.view_warehouse"/>
            <field name="arch" type="xml">
                <!-- Ubicamos el campo 'code' (Código corto de bodega) y ponemos nuestro campo justo debajo -->
                <xpath expr="//field[@name='code']" position="after">
                    <field name="enable_auto_fix"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>